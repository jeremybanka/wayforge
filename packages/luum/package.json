{
	"name": "luum",
	"version": "0.0.17",
	"type": "module",
	"description": "generate colors dynamically",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsdown src/index.ts --format=esm --dts --platform=neutral",
		"dev": "cd example && vite",
		"lint:eslint": "eslint -- .",
		"lint:oxlint": "oxlint --type-aware -c ../../.oxlintrc.jsonc .",
		"lint:types": "tsc --noEmit",
		"watch:types": "tsc --watch --noEmit",
		"lint": "concurrently \"bun:lint:*\"",
		"test": "vitest",
		"test:once": "vitest run",
		"postversion": "dprint fmt package.json"
	},
	"devDependencies": {
		"@types/node": "25.9.5",
		"concurrently": "10.0.3",
		"eslint": "10.6.0",
		"tsdown": "0.22.4",
		"typescript": "7.0.2",
		"vite": "8.1.4",
		"vitest": "4.1.10"
	},
	"keywords": [
		"color",
		"css",
		"javascript",
		"library"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeremybanka/wayforge.git",
		"directory": "packages/luum"
	},
	"license": "MIT",
	"author": "Jeremy Banka",
	"publishConfig": {
		"access": "public"
	}
}
