{
	"name": "varmint",
	"type": "module",
	"version": "0.5.18",
	"license": "MIT",
	"author": {
		"name": "Jeremy Banka",
		"email": "hello@jeremybanka.com"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeremybanka/wayforge.git",
		"directory": "packages/varmint"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"module": "dist/index.js",
	"bin": {
		"varmint": "bin/varmint.bin.js"
	},
	"files": [
		"dist",
		"src",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsdown && rm -f dist/*.x.d.ts",
		"clean:build": "rm -rf dist",
		"lint:eslint": "eslint -- .",
		"lint:oxlint": "oxlint --type-aware -c ../../.oxlintrc.jsonc .",
		"lint:types": "tsgo --noEmit",
		"watch:types": "tsgo --watch --noEmit",
		"lint": "concurrently \"bun:lint:*\"",
		"test": "vitest",
		"test:once": "./bin/varmint.bin.js track && vitest run; ./bin/varmint.bin.js clean --ci-flag=CI",
		"postversion": "dprint fmt package.json"
	},
	"dependencies": {
		"arktype": "2.2.3",
		"cachedir": "2.4.0",
		"comline": "workspace:*",
		"diff": "9.0.0",
		"fastest-levenshtein": "1.0.16",
		"safedeposit": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "npm:bun-types@1.3.14",
		"@types/node": "25.9.5",
		"@typescript/native-preview": "7.0.0-dev.20260707.2",
		"atom.io": "0.49.7",
		"concurrently": "10.0.3",
		"eslint": "10.6.0",
		"openai": "6.45.0",
		"tsdown": "0.22.4",
		"vite": "8.1.4",
		"vitest": "4.1.10",
		"yalc": "1.0.0-pre.53",
		"zod": "4.4.3"
	}
}
