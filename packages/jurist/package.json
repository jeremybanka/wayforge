	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeremybanka/wayforge.git",
		"directory": "packages/jurist"
	},
	"type": "module",
	"files": [
		"dist",
		"src"
	],
	"main": "dist/jurist.js",
	"scripts": {
		"build": "tsdown",
		"lint:eslint": "eslint -- .",
		"lint:oxlint": "oxlint --type-aware -c ../../.oxlintrc.jsonc .",
		"lint:types": "tsc --noEmit",
