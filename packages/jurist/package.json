	"dependencies": {
		"treetrunks": "workspace:*"
	},
	"devDependencies": {
		"typescript": "7.0.2",
		"concurrently": "10.0.3",
		"eslint": "10.6.0",
		"tsdown": "0.22.4",
		"vite": "8.1.4",
		"vitest": "4.1.10"
	}
