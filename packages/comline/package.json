	"license": "MIT",
	"author": {
		"name": "Jeremy Banka",
		"email": "hello@jeremybanka.com"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeremybanka/wayforge.git",
		"directory": "packages/comline"
	},
	"type": "module",
	"files": [
		"dist",
		"src"
	],
	"main": "dist/cli.js",
	"types": "dist/cli.d.ts",
	"peerDependencies": {
		"arktype": "^2.1.28",
		"zod": "^4.2.0"
	},
	"peerDependenciesMeta": {
		"arktype": {
			"optional": true
		},
		"zod": {
			"optional": true
		}
	},
	"dependencies": {
		"@standard-schema/spec": "1.1.0",
		"treetrunks": "workspace:*"
	},
	"scripts": {
		"build": "tsdown",
		"lint:eslint": "eslint -- .",
		"lint:oxlint": "oxlint --type-aware -c ../../.oxlintrc.jsonc .",
		"lint:types": "tsgo --noEmit",
		"watch:types": "tsgo --watch --noEmit",
		"lint": "concurrently \"bun:lint:*\"",
		"test": "vitest",
		"test:once": "vitest run",
		"postversion": "dprint fmt package.json"
	},
	"devDependencies": {
		"@types/bun": "npm:bun-types@1.3.14",
		"@types/node": "25.9.4",
		"@typescript/native-preview": "7.0.0-dev.20260629.1",
		"arktype": "2.2.1",
		"concurrently": "10.0.3",
		"eslint": "10.6.0",
		"tsdown": "0.22.3",
		"vite": "8.1.0",
		"vitest": "4.1.9",
		"zod": "4.4.3"
	}
