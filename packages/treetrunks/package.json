{
	"name": "treetrunks",
	"description": "Lean utilities to build type-safe trees and validate routes through them.",
	"version": "0.1.8",
	"license": "MIT",
	"author": {
		"name": "Jeremy Banka",
		"email": "hello@jeremybanka.com"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeremybanka/wayforge.git",
		"directory": "packages/treetrunks"
	},
	"type": "module",
	"files": [
		"AGENTS.md",
		"__tests__",
		"dist",
		"src"
	],
	"main": "dist/treetrunks.js",
	"scripts": {
		"build": "tsdown",
		"lint:eslint": "eslint -- .",
		"lint:oxlint": "oxlint --type-aware -c ../../.oxlintrc.jsonc .",
		"lint:types": "tsgo --noEmit",
		"watch:types": "tsgo --watch --noEmit",
		"lint": "concurrently \"bun:lint:*\"",
		"test": "vitest",
		"test:coverage:once": "vitest run --coverage",
		"test:coverage:increased": "recoverage",
		"test:coverage": "pnpm test:coverage:once && pnpm test:coverage:increased",
		"test:once": "vitest run",
		"postversion": "dprint fmt package.json"
	},
	"devDependencies": {
		"@types/node": "25.9.4",
		"@typescript/native-preview": "7.0.0-dev.20260623.1",
		"@vitest/coverage-v8": "4.1.9",
		"concurrently": "10.0.3",
		"eslint": "10.5.0",
		"recoverage": "0.1.16",
		"tsdown": "0.22.3",
		"vite": "8.0.16",
		"vitest": "4.1.9"
	}
}
