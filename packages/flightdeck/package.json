{
	"name": "flightdeck",
	"version": "0.4.15",
	"license": "MIT",
	"author": {
		"name": "Jeremy Banka",
		"email": "hello@jeremybanka.com"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeremybanka/wayforge.git",
		"directory": "packages/flightdeck"
	},
	"type": "module",
	"files": [
		"dist",
		"gen",
		"src"
	],
	"main": "dist/lib.js",
	"types": "dist/lib.d.ts",
	"bin": {
		"flightdeck": "./bin/flightdeck.bin.js",
		"klaxon": "./bin/klaxon.bin.js"
	},
	"peerDependencies": {
		"zod": "^4"
	},
	"dependencies": {
		"@t3-oss/env-core": "0.13.11",
		"arktype": "2.2.3",
		"atom.io": "0.50.0",
		"comline": "workspace:*",
		"cron": "4.4.0",
		"safedeposit": "workspace:*"
	},
	"scripts": {
		"gen": "bun ./__scripts__/gen.bun.ts",
		"build": "tsdown && rm -f dist/*.x.d.ts && bun ./__scripts__/build-lnav.bun.ts",
		"schema:flightdeck": "bun ./src/flightdeck.bin.ts --outdir=dist -- schema",
		"lint:eslint": "eslint -- .",
		"lint:oxlint": "oxlint --type-aware -c ../../.oxlintrc.jsonc .",
		"lint:types": "tsc --noEmit",
		"watch:types": "tsc --watch --noEmit",
		"lint": "concurrently \"bun:lint:*\"",
		"test": "vitest",
		"test:once": "vitest run",
		"postversion": "dprint fmt package.json"
	},
	"devDependencies": {
		"@biomejs/js-api": "6.0.0",
		"@biomejs/wasm-nodejs": "2.5.4",
		"@types/bun": "npm:bun-types@1.3.14",
		"@types/node": "25.9.5",
		"typescript": "7.0.2",
		"concurrently": "10.0.3",
		"eslint": "10.7.0",
		"json-schema-to-zod": "2.8.1",
		"tsdown": "0.22.9",
		"varmint": "workspace:*",
		"vitest": "4.1.10",
		"zod": "4.4.3"
	}
}
