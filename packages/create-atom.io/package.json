{
	"name": "create-atom.io",
	"version": "0.1.23",
	"license": "MIT",
	"author": {
		"name": "Jeremy Banka",
		"email": "hello@jeremybanka.com"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeremybanka/wayforge.git",
		"directory": "packages/create-atom"
	},
	"type": "module",
	"files": [
		"bin",
		"dist",
		"src",
		"templates"
	],
	"main": "dist/create-atom.js",
	"types": "dist/create-atom.d.ts",
	"bin": "./bin/create-atom.bin.js",
	"dependencies": {
		"@atom.io/template-preact-svg-editor": "workspace:*",
		"@atom.io/template-react-node-backend": "workspace:*",
		"@atom.io/template-solid-lossless-numbers": "workspace:*",
		"@clack/prompts": "1.5.1",
		"arktype": "2.2.0",
		"comline": "workspace:*",
		"local-pkg": "1.2.1",
		"tinyexec": "1.2.4"
	},
	"scripts": {
		"build": "tsdown && rm -f dist/*.x.d.ts",
		"lint:biome": "biome check -- .",
		"lint:eslint": "eslint -- .",
		"lint:types": "tsgo --noEmit",
		"watch:types": "tsgo --watch --noEmit",
		"lint": "concurrently \"bun:lint:*\""
	},
	"devDependencies": {
		"@types/bun": "npm:bun-types@1.3.14",
		"@types/node": "25.9.1",
		"@typescript/native-preview": "7.0.0-dev.20260605.1",
		"concurrently": "10.0.3",
		"eslint": "10.4.1",
		"tsdown": "0.22.1"
	}
}
