{
	"name": "ingt",
	"version": "0.0.2",
	"type": "module",
	"description": "json filestore",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts",
		"lint:eslint": "eslint -- .",
		"lint:oxlint": "oxlint --type-aware -c ../../.oxlintrc.jsonc .",
		"lint:types": "tsc --noEmit",
		"watch:types": "tsc --watch --noEmit",
		"lint": "concurrently \"bun:lint:*\"",
		"test": "vitest",
		"test:once": "vitest run",
		"postversion": "dprint fmt package.json"
	},
	"dependencies": {
		"anvl": "workspace:*",
		"atom.io": "0.49.7",
		"fp-ts": "2.16.11",
		"io-ts": "2.2.22"
	},
	"devDependencies": {
		"@types/node": "25.9.5",
		"typescript": "7.0.2",
		"concurrently": "10.0.3",
		"eslint": "10.6.0",
		"tsdown": "0.22.4",
		"vite": "8.1.4",
		"vitest": "4.1.10"
	},
	"peerDependencies": {
		"fp-ts": "^2.13.1",
		"io-ts": "^2.2.20"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeremybanka/wayforge.git",
		"directory": "packages/ingt"
	},
	"license": "MIT",
	"sideEffects": false,
	"author": "Jeremy Banka",
	"publishConfig": {
		"access": "public"
	}
