{
	"name": "venerate",
	"version": "0.0.3",
	"license": "MIT",
	"author": {
		"name": "Jeremy Banka",
		"email": "hello@jeremybanka.com"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeremybanka/wayforge.git",
		"directory": "packages/venerate"
	},
	"type": "module",
	"files": [
		"dist",
		"src"
	],
	"main": "dist/venerate.js",
	"scripts": {
		"build": "tsdown",
		"lint:eslint": "eslint -- .",
		"lint:oxlint": "oxlint --type-aware -c ../../.oxlintrc.jsonc .",
		"lint:types": "tsc --noEmit",
		"watch:types": "tsc --watch --noEmit",
		"lint": "concurrently \"bun:lint:*\"",
		"test": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:once": "vitest run",
		"postversion": "dprint fmt package.json"
	},
	"devDependencies": {
		"@types/node": "25.9.5",
		"typescript": "7.0.2",
		"@vitest/coverage-v8": "4.1.10",
		"concurrently": "10.0.3",
		"eslint": "10.7.0",
		"recoverage": "0.1.16",
		"tsdown": "0.22.7",
		"vite": "8.1.4",
		"vitest": "4.1.10"
	}
}
