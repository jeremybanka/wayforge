{
	"name": "tempest.games",
	"version": "0.3.43",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeremybanka/wayforge.git",
		"directory": "apps/tempest.games"
	},
	"type": "module",
	"bin": {
		"frontend": "./bin/frontend.bun.js",
		"backend": "./bin/backend.bun.js",
		"setup-db": "./bin/setup-db.bun.js",
		"interactive-db": "./bin/interactive-db.bun.js"
	},
	"files": [
		"app",
		"bin",
		"CHANGELOG.md",
		"drizzle",
		"drizzle.config.ts",
		"index.html"
	],
	"scripts": {
		"dev": "bun run env:dev && concurrently \"bun:dev:*\"",
		"dev:vite": "vite --port 3333",
		"dev:backend": "bun --hot --no-clear-screen --env-file=.env.development ./src/backend.bun.ts",
		"dev:email": "bun --env-file=.env.development email dev",
		"dev:db": "pnpm run db:dev",
		"build": "rm -rf ./bin && ([ $PREVIEW ] && bun run env:pre || bun run env:prod) && concurrently \"bun:build:*\"",
		"build:bun": "./build.bun.ts",
		"build:vite": "[ $PREVIEW ] && vite build --mode preview || vite build --mode production",
		"preview": "PREVIEW=true nr build && concurrently \"bun:preview:*\"",
		"preview:frontend": "bun --env-file=.env.preview bin/frontend.bun.js",
		"preview:backend": "bun --env-file=.env.preview bin/backend.bun.js",
		"env:dev": "[ -f .env.development ] && echo '.env.development already present' || cp .env.defaults .env.development",
		"env:pre": "[ -f .env.preview ] && echo '.env.preview already present' || cp .env.defaults .env.preview",
		"env:test": "[ -f .env.test ] && echo '.env.test already present' || cp .env.defaults .env.test",
		"env:prod": "[ -f .env.production ] && echo '.env.production already present' || echo 'VITE_BACKEND_ORIGIN=https://realtime.tempest.games' >> .env.production && echo 'VITE_HIDE_DEVTOOLS=true' >> .env.production",
		"test": "bun env:test && vitest",
		"test:once": "bun env:test && varmint track && vitest run; varmint clean --ci-flag=CI",
		"lint:eslint": "eslint -- .",
		"lint:oxlint": "oxlint --type-aware -c ../../.oxlintrc.jsonc .",
		"lint:types": "tsc --noEmit",
		"watch:types": "tsc --watch --noEmit",
		"lint": "concurrently \"bun:lint:*\"",
		"db:dev": "dotenvx run -f .env.development -- ./__scripts__/interactive-db.bun.ts",
		"db:gen": "dotenvx run -f .env.development -- drizzle-kit generate",
		"db:nuke": "./__scripts__/destroy-db.bun.ts",
		"db:setup": "./__scripts__/setup-db.bun.ts"
	},
	"dependencies": {
		"@ai-sdk/openai": "4.0.9",
		"@floating-ui/react": "0.27.19",
		"@js-temporal/polyfill": "0.5.1",
		"@react-spring/three": "10.1.2",
		"@react-three/drei": "10.7.7",
		"@react-three/fiber": "9.6.1",
		"@t3-oss/env-core": "0.13.11",
		"@trpc/client": "11.18.0",
		"@trpc/server": "11.18.0",
		"ai": "7.0.18",
		"arktype": "2.2.3",
		"atom.io": "0.49.7",
		"cron": "4.4.0",
		"drizzle-orm": "0.45.2",
		"motion": "12.42.2",
		"nanoid": "5.1.16",
		"openai": "6.45.0",
		"postgres": "3.4.9",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-email": "6.6.9",
		"resend": "6.17.2",
		"safedeposit": "workspace:*",
		"socket.io": "4.8.3",
		"socket.io-client": "4.8.3",
		"three": "0.185.1",
		"three-stdlib": "2.36.1",
		"treetrunks": "workspace:*",
		"varmint": "workspace:*"
	},
	"devDependencies": {
		"@react-email/ui": "6.6.9",
		"@types/bun": "npm:bun-types@1.3.14",
		"@types/cors": "2.8.19",
		"@types/node": "25.9.5",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@types/three": "0.185.1",
		"@vitejs/plugin-react": "npm:@vitejs/plugin-react-swc@4.3.1",
		"concurrently": "10.0.3",
		"cors": "2.8.6",
		"drizzle-kit": "0.31.10",
		"eslint": "10.6.0",
		"flightdeck": "workspace:*",
		"globals": "17.7.0",
		"typescript": "7.0.2",
		"vite": "8.1.4",
		"vitest": "4.1.10"
	}
}
