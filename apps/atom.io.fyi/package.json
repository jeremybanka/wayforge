{
	"name": "atom.io.fyi",
	"type": "module",
	"version": "0.2.64",
	"private": true,
	"engines": {
		"node": "26.2.0"
	},
	"scripts": {
		"dev": "concurrently \"bun:dev:*\"",
		"dev:astro": "astro dev",
		"dev:exhibits": "./scripts/exhibits.bun.ts watch",
		"build": "bun run build:agent-docs && bun run build:exhibits && bun run build:astro",
		"build:agent-docs": "../../packages/atom.io/__scripts__/agent-docs.bun.ts --site",
		"build:astro": "astro build",
		"build:exhibits": "./scripts/exhibits.bun.ts once",
		"preview": "wrangler dev",
		"deploy": "wrangler deploy",
		"astro": "astro",
		"lint:eslint": "eslint -- .",
		"lint:oxlint": "oxlint --type-aware -c ../../.oxlintrc.jsonc .",
		"lint:types": "tsgo --noEmit"
	},
	"dependencies": {
		"@astrojs/cloudflare": "13.6.1",
		"@astrojs/mdx": "6.0.2",
		"@astrojs/preact": "5.1.5",
		"astro": "6.4.4",
		"atom.io": "workspace:*",
		"preact": "10.29.2",
		"react": "npm:@preact/compat@18.3.2",
		"react-dom": "npm:@preact/compat@18.3.2",
		"react-syntax-highlighter": "16.1.1",
		"tsdoc.json": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "npm:bun-types@1.3.14",
		"@types/react": "19.2.17",
		"@types/react-syntax-highlighter": "15.5.13",
		"@typescript/native-preview": "7.0.0-dev.20260606.1",
		"chokidar": "5.0.0",
		"concurrently": "10.0.3",
		"eslint": "10.4.1",
		"takua": "workspace:*",
		"wrangler": "4.98.0"
	}
}
