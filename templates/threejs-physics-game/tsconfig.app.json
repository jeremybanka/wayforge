{
	"compilerOptions": {
		"target": "ES2024",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"strict": true,
		"allowImportingTsExtensions": true,
		"exactOptionalPropertyTypes": true,
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"types": ["vite/client"]
	},
	"include": ["src", "vite.config.ts"]
}
