{
	"name": "@wayforge/monorepo",
	"version": "0.0.0",
	"description": "choose your path",
	"type": "module",
	"repository": "https://github.com/jeremybanka/wayforge",
	"author": "jeremybanka",
	"license": "GPL-3.0",
	"private": true,
	"packageManager": "pnpm@11.3.0",
	"engines": {
		"node": "26.2.0"
	},
	"workspaces": [
		"apps/*",
		"packages/*",
		"templates/*"
	],
	"scripts": {
		"gen": "dotenvx run -- turbo run gen",
		"lint": "dotenvx run -- turbo run lint",
		"lint:biome": "dotenvx run -- turbo run lint:biome",
		"lint:deps": "pin-checker --ignore-workspaces",
		"lint:eslint": "dotenvx run -- turbo run lint:eslint",
		"lint:types": "dotenvx run -- turbo run lint:types",
		"watch:types": "dotenvx run -- turbo run watch:types --concurrency=30",
		"lint:fix:biome": "biome check --write *",
		"lint:fix:eslint": "eslint --fix .",
		"fmt": "biome format .",
		"fmt:fix": "biome format --write .",
		"build": "dotenvx run -- turbo run build",
		"bench": "cd lib && vitest bench",
		"test": "cross-env CI=true dotenvx run -- turbo run test:once --concurrency=2",
		"test:coverage:increased": "cross-env CI=true turbo run test:coverage:increased",
		"test:semver": "cross-env CI=true dotenvx run -- turbo run test:semver",
		"release": "bun run build && changeset publish",
		"notes": "changeset",
		"vigilance": "bun lib/vigilance-bot.bun.ts",
		"nuke": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name 'dist' -type d -prune -exec rm -rf '{}' + && rm pnpm-lock.yaml",
		"nv": "fnm use $(pnpm list -w --json | jq -r '.[0].path')",
		"version": "dotenvx run -- turbo run version",
		"upgrade-workflows": "bun lib/update-workflows.bun.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@changesets/cli": "2.31.0",
		"@changesets/config": "3.1.4",
		"@dotenvx/dotenvx": "1.69.1",
		"@types/eslint": "9.6.1",
		"@typescript-eslint/eslint-plugin": "8.60.0",
		"@typescript-eslint/parser": "8.60.0",
		"@typescript-eslint/utils": "8.60.0",
		"@typescript/native-preview": "7.0.0-dev.20260526.1",
		"cross-env": "10.1.0",
		"eslint-plugin-drizzle": "0.2.3",
		"eslint-plugin-import-x": "4.16.2",
		"eslint-plugin-simple-import-sort": "13.0.0",
		"eslint-plugin-storybook": "10.4.1",
		"jiti": "2.7.0",
		"pin-dependencies-checker": "2.7.1",
		"turbo": "2.9.14",
		"typescript": "6.0.3",
		"vite-tsconfig-paths": "6.1.1",
		"vitest": "4.1.7"
	}
}
